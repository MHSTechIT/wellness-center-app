# ===== WellnessOS backend (server) =====
PORT=4000
# Comma-separated list of allowed client origins (CORS). Leave empty in dev to allow all.
CORS_ORIGIN=http://localhost:3000

# ----- Supabase (server) -----
# Prefer server-only names. A service-role key is recommended for a backend;
# the anon key also works (matches previous behaviour).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ----- Meta / Facebook Lead Ads -----
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_SYSTEM_ACCESS_TOKEN=
META_PAGE_IDS=
META_TARGET_AD_ACCOUNTS=

# ----- Tata Tele / Smartflo telephony -----
TATA_TELE_API_KEY=
TATA_TELE_CALLER_ID=
TATA_TELE_DEFAULT_EXTENSION_NUMBER=
TATA_TELE_DEFAULT_AGENT_NUMBER=
TATA_TELE_USE_SUPPORT_FALLBACK=0
